{
  "__inputs": [
    {
      "name": "DS_POSTGRESQL",
      "label": "PostgreSQL / TimescaleDB",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "10.0.0" },
    { "type": "datasource", "id": "postgres",   "name": "PostgreSQL", "version": "1.0.0"  },
    { "type": "panel",      "id": "stat",       "name": "Stat",       "version": "" },
    { "type": "panel",      "id": "timeseries", "name": "Time series","version": "" }
  ],
  "uid": "twstock-macro",
  "title": "01 - 總經流動性",
  "tags": ["twstock", "macro"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1h",
  "time": { "from": "now-90d", "to": "now" },
  "timepicker": {},
  "graphTooltip": 1,
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "stat",
      "title": "FED 基準利率 (%)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 3.0  },
            { "color": "red",    "value": 5.0  }
          ]}
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT value FROM macro_indicators WHERE indicator='FED_RATE' ORDER BY time DESC LIMIT 1",
        "format": "table", "rawQuery": true
      }]
    },
    {
      "id": 2, "type": "stat",
      "title": "美10年期公債 UST 10Y (%)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 3,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 4.0  },
            { "color": "red",    "value": 4.5  }
          ]}
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT value FROM macro_indicators WHERE indicator='UST_10Y' ORDER BY time DESC LIMIT 1",
        "format": "table", "rawQuery": true
      }]
    },
    {
      "id": 3, "type": "stat",
      "title": "CPI 指數 (CPIAUCSL)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 310  },
            { "color": "red",    "value": 330  }
          ]}
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT value FROM macro_indicators WHERE indicator='CPI_YOY' ORDER BY time DESC LIMIT 1",
        "format": "table", "rawQuery": true
      }]
    },
    {
      "id": 4, "type": "stat",
      "title": "USD/TWD 匯率",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 3,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 32.0 },
            { "color": "red",    "value": 33.0 }
          ]}
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT value FROM macro_indicators WHERE indicator='USDTWD' ORDER BY time DESC LIMIT 1",
        "format": "table", "rawQuery": true
      }]
    },
    {
      "id": 5, "type": "timeseries",
      "title": "美10年期公債殖利率 UST 10Y — 警戒線 4.5%",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 9 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "percent", "decimals": 3,
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red",   "value": 4.5  }
          ]}
        }
      },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT time AS \"time\", value AS \"UST 10Y (%)\" FROM macro_indicators WHERE indicator='UST_10Y' AND $__timeFilter(time) ORDER BY time",
        "format": "time_series", "rawQuery": true
      }]
    },
    {
      "id": 6, "type": "timeseries",
      "title": "FED 基準利率 (%)",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "percent", "decimals": 2,
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT time AS \"time\", value AS \"FED Rate (%)\" FROM macro_indicators WHERE indicator='FED_RATE' AND $__timeFilter(time) ORDER BY time",
        "format": "time_series", "rawQuery": true
      }]
    },
    {
      "id": 7, "type": "timeseries",
      "title": "CPI 指數 (CPIAUCSL)",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "short", "decimals": 1,
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT time AS \"time\", value AS \"CPI Index\" FROM macro_indicators WHERE indicator='CPI_YOY' AND $__timeFilter(time) ORDER BY time",
        "format": "time_series", "rawQuery": true
      }]
    },
    {
      "id": 8, "type": "timeseries",
      "title": "USD/TWD 匯率",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "short", "decimals": 3,
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT time AS \"time\", value AS \"USD/TWD\" FROM macro_indicators WHERE indicator='USDTWD' AND $__timeFilter(time) ORDER BY time",
        "format": "time_series", "rawQuery": true
      }]
    }
  ]
}
