{
  "__inputs": [
    {
      "name": "DS_TWSTOCK",
      "label": "TWStock TimescaleDB",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "title": "04 · 多因子訊號與告警",
  "uid": "twstock-signals",
  "description": "多因子篩選結果、估值模型訊號、系統告警",
  "tags": ["twstock", "signals", "alerts"],
  "timezone": "Asia/Taipei",
  "time": { "from": "now-7d", "to": "now" },
  "refresh": "5m",
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "今日多因子全通過清單 (score = 4)",
      "description": "同時通過基本面、籌碼面、估值面、技術面四個濾網",
      "type": "table",
      "gridPos": { "x": 0, "y": 0, "w": 14, "h": 10 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT s.ticker AS \"代號\", s.name AS \"名稱\", s.industry AS \"產業\", m.score AS \"得分\", CASE WHEN m.filter1_fundamental THEN '✅' ELSE '❌' END AS \"基本面 YoY>15%\", CASE WHEN m.filter2_institutional THEN '✅' ELSE '❌' END AS \"籌碼 投信+大戶\", CASE WHEN m.filter3_valuation THEN '✅' ELSE '❌' END AS \"估值 P/E合理\", CASE WHEN m.filter4_technical THEN '✅' ELSE '❌' END AS \"技術 突破+量能\" FROM multi_factor_signals m JOIN stocks s ON s.ticker = m.ticker WHERE m.time >= CURRENT_DATE AND m.all_passed = TRUE ORDER BY m.score DESC, s.ticker",
          "format": "table"
        }
      ],
      "options": {
        "sortBy": [{ "displayName": "得分", "desc": true }]
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "得分" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "yellow", "value": 3 },
                    { "color": "green", "value": 4 }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 2,
      "title": "今日各 Filter 通過比例",
      "type": "piechart",
      "gridPos": { "x": 14, "y": 0, "w": 10, "h": 10 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT '基本面 YoY>15%' AS filter, COUNT(*) FILTER (WHERE filter1_fundamental) AS passed FROM multi_factor_signals WHERE time >= CURRENT_DATE UNION ALL SELECT '籌碼 投信+大戶', COUNT(*) FILTER (WHERE filter2_institutional) FROM multi_factor_signals WHERE time >= CURRENT_DATE UNION ALL SELECT '估值 P/E合理', COUNT(*) FILTER (WHERE filter3_valuation) FROM multi_factor_signals WHERE time >= CURRENT_DATE UNION ALL SELECT '技術 突破+量能', COUNT(*) FILTER (WHERE filter4_technical) FROM multi_factor_signals WHERE time >= CURRENT_DATE",
          "format": "table"
        }
      ]
    },
    {
      "id": 3,
      "title": "近 7 日多因子訊號熱力圖 (score 分布)",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 10, "w": 14, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT DATE(time) AS time, COUNT(*) FILTER (WHERE score = 4) AS \"4分 (全通過)\", COUNT(*) FILTER (WHERE score = 3) AS \"3分\", COUNT(*) FILTER (WHERE score = 2) AS \"2分\", COUNT(*) FILTER (WHERE score <= 1) AS \"0-1分\" FROM multi_factor_signals WHERE $__timeFilter(time) GROUP BY DATE(time) ORDER BY DATE(time)",
          "format": "time_series"
        }
      ],
      "options": { "stacking": "normal" },
      "fieldConfig": {
        "defaults": { "unit": "none" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "4分 (全通過)" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "3分" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "2分" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "0-1分" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      }
    },
    {
      "id": 4,
      "title": "估值訊號總覽 (最新一次評估)",
      "type": "table",
      "gridPos": { "x": 14, "y": 10, "w": 10, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT v.ticker AS \"代號\", s.name AS \"名稱\", v.model AS \"模型\", ROUND(v.current_price, 1) AS \"現價\", ROUND(v.intrinsic_value, 1) AS \"合理價\", ROUND(v.ratio, 2) AS \"價值比\", v.signal AS \"訊號\" FROM valuation_scores v JOIN stocks s ON s.ticker = v.ticker WHERE (v.ticker, v.model, v.time) IN ( SELECT ticker, model, MAX(time) FROM valuation_scores GROUP BY ticker, model ) AND v.signal = 'UNDERVALUED' ORDER BY v.ratio ASC LIMIT 20",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "訊號" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "UNDERVALUED": { "color": "green", "index": 0 } } },
                  { "type": "value", "options": { "FAIR": { "color": "yellow", "index": 1 } } },
                  { "type": "value", "options": { "OVERVALUED": { "color": "red", "index": 2 } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "價值比" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 0.9 },
                    { "color": "red", "value": 1.1 }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 5,
      "title": "未讀告警",
      "type": "table",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 10 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT created_at AS \"時間\", COALESCE(ticker, '大盤') AS \"標的\", severity AS \"嚴重度\", alert_type AS \"類型\", message AS \"訊息\" FROM alerts WHERE acknowledged = FALSE AND $__timeFilter(created_at) ORDER BY created_at DESC LIMIT 50",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "嚴重度" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "INFO":     { "color": "blue",   "index": 0 } } },
                  { "type": "value", "options": { "WARNING":  { "color": "yellow", "index": 1 } } },
                  { "type": "value", "options": { "CRITICAL": { "color": "red",    "index": 2 } } }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "title": "告警統計 (近 7 日)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 28, "w": 8, "h": 5 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) FILTER (WHERE severity = 'CRITICAL') AS \"CRITICAL\", COUNT(*) FILTER (WHERE severity = 'WARNING') AS \"WARNING\", COUNT(*) FILTER (WHERE severity = 'INFO') AS \"INFO\" FROM alerts WHERE created_at >= NOW() - INTERVAL '7 days'",
          "format": "table"
        }
      ],
      "options": { "colorMode": "background", "orientation": "horizontal" },
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "CRITICAL" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "WARNING"  }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "INFO"     }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] }
        ]
      }
    }
  ]
}
