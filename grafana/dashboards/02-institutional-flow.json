{
  "__inputs": [
    {
      "name": "DS_TWSTOCK",
      "label": "TWStock TimescaleDB",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "title": "02 · 籌碼面",
  "uid": "twstock-institutional",
  "description": "三大法人買賣超、外資期貨淨未平倉、千張大戶、融資融券",
  "tags": ["twstock", "institutional"],
  "timezone": "Asia/Taipei",
  "time": { "from": "now-3M", "to": "now" },
  "refresh": "1h",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "ticker",
        "label": "股票代號",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
        "query": "SELECT ticker || ' ' || name FROM stocks ORDER BY ticker",
        "regex": "^(\\S+)",
        "current": {},
        "multi": false,
        "includeAll": false,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "三大法人買賣超 — $ticker (張)",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 9 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT time, foreign_net AS \"外資\", trust_net AS \"投信\", dealer_net AS \"自營商\", total_net AS \"三大法人合計\" FROM institutional_flows WHERE ticker = '$ticker' AND $__timeFilter(time) ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "三大法人合計" }, "properties": [{ "id": "custom.lineWidth", "value": 2 }] }
        ]
      },
      "options": {
        "groupWidth": 0.7,
        "stacking": "none"
      }
    },
    {
      "id": 2,
      "title": "外資累積買賣超 — $ticker (張)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT time, SUM(foreign_net) OVER (ORDER BY time) AS \"外資累積\" FROM institutional_flows WHERE ticker = '$ticker' AND $__timeFilter(time) ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" }
        }
      }
    },
    {
      "id": 3,
      "title": "投信累積買賣超 — $ticker (張)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT time, SUM(trust_net) OVER (ORDER BY time) AS \"投信累積\" FROM institutional_flows WHERE ticker = '$ticker' AND $__timeFilter(time) ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" }
        }
      }
    },
    {
      "id": 4,
      "title": "外資台指期淨未平倉 (口) — 警戒線 -30,000",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 17, "w": 16, "h": 9 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT time, foreign_net AS \"外資淨未平倉\", dealer_net AS \"自營商淨未平倉\" FROM futures_positions WHERE $__timeFilter(time) ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": -20000 },
              { "color": "red", "value": -30000 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          }
        }
      }
    },
    {
      "id": 5,
      "title": "外資期貨最新部位",
      "type": "stat",
      "gridPos": { "x": 16, "y": 17, "w": 8, "h": 9 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT foreign_long AS \"多單\", foreign_short AS \"空單\", foreign_net AS \"淨部位\" FROM futures_positions ORDER BY time DESC LIMIT 1",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "vertical",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": -30000 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "千張大戶 vs 散戶持股比例 — $ticker (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT time, holders_1000_ratio AS \"千張大戶 (%)\", retail_ratio AS \"散戶 < 10張 (%)\" FROM major_holders WHERE ticker = '$ticker' AND $__timeFilter(time) ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 7,
      "title": "融資融券餘額 — $ticker",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT time, margin_balance AS \"融資餘額 (千元)\", short_balance AS \"融券餘額 (張)\" FROM margin_trading WHERE ticker = '$ticker' AND $__timeFilter(time) ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "custom": { "lineWidth": 2 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "融資餘額 (千元)" },
            "properties": [{ "id": "custom.axisPlacement", "value": "left" }]
          },
          {
            "matcher": { "id": "byName", "options": "融券餘額 (張)" },
            "properties": [{ "id": "custom.axisPlacement", "value": "right" }]
          }
        ]
      }
    }
  ]
}
