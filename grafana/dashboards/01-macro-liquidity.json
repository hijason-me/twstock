{
  "__inputs": [
    {
      "name": "DS_TWSTOCK",
      "label": "TWStock TimescaleDB",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "title": "01 · 總經與資金環境",
  "uid": "twstock-macro",
  "description": "Fed 利率、美債殖利率、CPI/PCE、台幣匯率",
  "tags": ["twstock", "macro"],
  "timezone": "Asia/Taipei",
  "time": { "from": "now-1y", "to": "now" },
  "refresh": "1h",
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "Fed 基準利率 (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT time, value AS \"Fed 基準利率\" FROM macro_indicators WHERE indicator = 'FED_RATE' AND $__timeFilter(time) ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 2,
      "title": "美債殖利率 10Y (%) — 警戒線 4.5%",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT time, value AS \"10Y 殖利率\" FROM macro_indicators WHERE indicator = 'UST_10Y' AND $__timeFilter(time) ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 4 },
              { "color": "red", "value": 4.5 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line+area" }
          }
        }
      }
    },
    {
      "id": 3,
      "title": "美國 CPI YoY (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT time, value AS \"CPI YoY\" FROM macro_indicators WHERE indicator = 'CPI_YOY' AND $__timeFilter(time) ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2.5 },
              { "color": "red", "value": 4 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 4,
      "title": "美國 PCE YoY (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT time, value AS \"PCE YoY\" FROM macro_indicators WHERE indicator = 'PCE_YOY' AND $__timeFilter(time) ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2.5 },
              { "color": "red", "value": 4 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 5,
      "title": "台幣匯率 USD/TWD",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 16, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT time, value AS \"USD/TWD\" FROM macro_indicators WHERE indicator = 'USDTWD' AND $__timeFilter(time) ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 3,
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity"
          }
        }
      }
    },
    {
      "id": 6,
      "title": "總經最新數值",
      "type": "table",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_TWSTOCK}" },
      "targets": [
        {
          "rawSql": "SELECT indicator AS \"指標\", ROUND(value::numeric, 4) AS \"最新值\", time AS \"更新時間\" FROM macro_indicators WHERE (indicator, time) IN ( SELECT indicator, MAX(time) FROM macro_indicators GROUP BY indicator ) ORDER BY indicator",
          "format": "table"
        }
      ],
      "options": { "sortBy": [{ "displayName": "指標" }] }
    }
  ]
}
